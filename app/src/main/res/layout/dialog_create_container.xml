<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 容器名称输入 -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_container_name"
        app:boxStrokeWidth="2dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etContainerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- proot 选择按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogProot"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:text="@string/btn_select_proot"
        app:icon="@drawable/ic_file"
        app:iconGravity="textStart"
        app:strokeWidth="2dp" />

    <!-- rootfs 选择按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogRootfs"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="@string/btn_select_rootfs"
        app:icon="@drawable/ic_archive"
        app:iconGravity="textStart"
        app:strokeWidth="2dp" />

    <!-- 状态提示 -->
    <TextView
        android:id="@+id/tvDialogStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="@color/md_error"
        android:visibility="gone" />

</LinearLayout>